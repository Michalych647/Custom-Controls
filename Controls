local function ujv(cpos, df)
	stick.Position = UDim2.new(0, cpos.X - 22.5, 0, cpos.Y - 22.5)
	for i, dt in ipairs(dots) do
		local rt = i / 7
		local dpos = spos + (df * rt)
		dt.Position = UDim2.new(0, dpos.X - (dt.Size.X.Offset / 2), 0, dpos.Y - (dt.Size.Y.Offset / 2))
	end

	local dst = df.Magnitude
	local dr = dst > 0 and df.Unit or Vector2.new(0, 0)
	local int = math.clamp(dst / 40, 0, 1)
	mvec = Vector3.new(dr.X * int, 0, dr.Y * int)
end

carea.InputBegan:Connect(function(inp)
	if not syson or drag then return end
	if inp.UserInputType ~= Enum.UserInputType.Touch and inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end

	if caani then
		caani = false
		carea.BackgroundTransparency = 1
	end

	drag = true
	monce = false
	inpo = inp
	spos = Vector2.new(inp.Position.X, inp.Position.Y)
end)

uis.InputChanged:Connect(function(inp)
	if syson and drag and inp == inpo then
		local cpos = Vector2.new(inp.Position.X, inp.Position.Y)
		local df = cpos - spos

		if not monce and df.Magnitude > 10 then
			monce = true
			base.Position = UDim2.new(0, spos.X - 20, 0, spos.Y - 20)
			base.Visible = true
			stick.Visible = true
			for _, d in pairs(dots) do d.Visible = true end
		end
		if monce then ujv(cpos, df) end
	end
end)

uis.InputEnded:Connect(function(inp)
	if inp == inpo then
		drag = false
		monce = false
		inpo = nil
		base.Visible = false
		stick.Visible = false
		for _, d in pairs(dots) do d.Visible = false end
		mvec = Vector3.new(0, 0, 0)
	end
end)

rs.Heartbeat:Connect(function(dt)
	local rpng = getPing()

	table.insert(phist, rpng)
	if #phist > mph then
		table.remove(phist, 1)
	end
	
	local psum = 0
	for _, v in ipairs(phist) do
		psum += v
	end
	local apng = psum / #phist

	sping = sping + (apng - sping) * 0.1

	local pingSec = sping / 1000
	ct = bct + (pingSec * 1.2)
	bt = bbt + (pingSec * 1.5)
end)
