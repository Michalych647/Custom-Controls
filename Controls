task.spawn(function()
    task.wait(0.1)
    captureAnim = true
    capArea.BackgroundTransparency = 0.5
    local elap = 0
    while elap < 1.5 do
        if not captureAnim then
            capArea.BackgroundTransparency = 1
            return
        end
        elap += task.wait()
    end
    if not captureAnim then
        capArea.BackgroundTransparency = 1
        return
    end
    local fElap = 0
    while fElap < 0.6 do
        if not captureAnim then
            capArea.BackgroundTransparency = 1
            return
        end
        fElap += task.wait()
        capArea.BackgroundTransparency = 0.5 + (0.5 * math.clamp(fElap / 0.6, 0, 1))
    end
    capArea.BackgroundTransparency = 1
    captureAnim = false
end)

local function reqJump()
    local hum = getHum()
    if not hum then return end

    if hum.Sit then
        hum.Sit = false
        hum.Jump = true
        lastJumpReq = tick()
        task.defer(function()
            if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
        end)
        return
    end

    local t = tick()
    local state = hum:GetState()
    local inAir = (hum.FloorMaterial == Enum.Material.Air)
    local canCoyote = (t - lastGrounded <= coyoteTime) and (lastGrounded > 0)

    if state == Enum.HumanoidStateType.Climbing then
        hum:ChangeState(Enum.HumanoidStateType.Jumping)
        return
    end

    if not inAir or canCoyote then
        lastGrounded = 0
        lastJumpReq = tick()
        hum:ChangeState(Enum.HumanoidStateType.Jumping)
        return
    end

    if inAir then
        lastJumpPress = t
    end
end

jumpBtn.MouseButton1Down:Connect(function()
    jumpBtn.BackgroundTransparency = 0.3
    jumpBtn.ImageColor3 = Color3.fromRGB(180, 180, 180)
    isHoldingJump = true
    reqJump()

    task.spawn(function()
        task.wait(0.2)
        while isHoldingJump do
            local hum = getHum()
            if hum and hum.FloorMaterial ~= Enum.Material.Air and not hum.Sit then
                lastJumpReq = tick()
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
            end
            task.wait(0.05)
        end
    end)
end)

