local function dcon()
	for _, c in ipairs(ccon) do
		if c and c.Connected then
			c:Disconnect()
		end
	end
	ccon = {}
end

local function isvst()
	local ch = plr.Character
	if not ch then return false end
	local hm = ch:FindFirstChildOfClass("Humanoid")
	if not hm then return false end
	if hm.Sit then
		local sp = hm.SeatPart
		if sp and sp:IsA("VehicleSeat") then
			return true
		end
	end
	return false
end

local function updst()
	local hm = gthm()
	if not hm then return end
	if hm.Sit and isvst() then
		endft()
	else
		encst()
	end
end

local function ftfr()
	local tgui = plr.PlayerGui:FindFirstChild("TouchGui")
	if not tgui then return nil end
	local frm = tgui:FindFirstChild("TouchControlFrame")
	return frm
end

local function fttf(frm)
	if not frm then return nil end
	local dthm = frm:FindFirstChild("DynamicThumbstickFrame")
	if dthm then return dthm end
	local stk = frm:FindFirstChild("DynamicThumbstick")
	if stk then
		local p = stk.Parent
		if p and p ~= frm then return p end
		return stk
	end
	return nil
end

local function ftjb(frm)
	if not frm then return nil end
	return frm:FindFirstChild("JumpButton")
end

local function synrc()
	local frm = ftfr()
	if not frm then return end

	local dthm = fttf(frm)
	if dthm then
		local pos = dthm.Position
		local sz = dthm.Size
		care.Size = sz
		care.Position = pos
	end

	local njmp = ftjb(frm)
	if njmp then
		local pos = njmp.Position
		local sz = njmp.Size
		jbtn.Position = pos
		jbtn.Size = sz
	end
end

local function setup(ch)
	dcon()
	lgt = 0
	ljpt = 0
	ljtt = 0
	jtc = 0
	wjct = 0
	wju = false
	ijh = false

	local hm = ch:WaitForChild("Humanoid", 5)
	if not hm then return end

	updst()
	local cs = hm:GetPropertyChangedSignal("Sit"):Connect(function()
		local hm2 = gthm()
		if not hm2 then return end
		if hm2.Sit and isvst() then
			endft()
		else
			encst()
			if drag and monc then
				base.Visible = true
				stck.Visible = true
				for _, d in pairs(dots) do d.Visible = true end
			end
		end
	end)
	table.insert(ccon, cs)

	local function hland()
		jtc = 0
		wju = false
		if tick() - ljpt <= bt then
			ljpt = 0
			task.defer(function()
				if hm and hm:GetState() ~= Enum.HumanoidStateType.Jumping then
					ljrt = tick()
					hm:ChangeState(Enum.HumanoidStateType.Jumping)
				end
			end)
		end
	end

	local c2 = hm.StateChanged:Connect(function(o, n)
		if n == Enum.HumanoidStateType.Freefall then
			if tick() - ljrt > 0.25 then
				lgt = tick()
			end
		end

		if n == Enum.HumanoidStateType.Landed or n == Enum.HumanoidStateType.Running or n == Enum.HumanoidStateType.RunningNoPhysics then
			hland()
		end
	end)
	table.insert(ccon, c2)

	local c3 = hm:GetPropertyChangedSignal("FloorMaterial"):Connect(function()
		if hm.FloorMaterial == Enum.Material.Air then
			if tick() - ljrt > 0.25 then
				lgt = tick()
			end
		else
			hland()
		end
	end)
	table.insert(ccon, c3)

	task.spawn(function()
		while true do
			if plr.Character ~= ch then break end
			local fnd = false
			pcall(function()
				local tgui = plr.PlayerGui:FindFirstChild("TouchGui")
				if tgui then
					local frm = tgui:FindFirstChild("TouchControlFrame")
					if frm then
						local dthm = fttf(frm)
						if dthm then
							table.insert(ccon, dthm:GetPropertyChangedSignal("Position"):Connect(synrc))
							table.insert(ccon, dthm:GetPropertyChangedSignal("Size"):Connect(synrc))
						end
						local njmp = ftjb(frm)
						if njmp then
							table.insert(ccon, njmp:GetPropertyChangedSignal("Position"):Connect(synrc))
							table.insert(ccon, njmp:GetPropertyChangedSignal("Size"):Connect(synrc))
							table.insert(ccon, njmp:GetPropertyChangedSignal("Visible"):Connect(function()
								if njmp.Visible then njmp.Visible = false end
							end))
							njmp.Visible = false
						end

						local stk = frm:FindFirstChild("DynamicThumbstick")
						if stk then
							table.insert(ccon, stk:GetPropertyChangedSignal("Visible"):Connect(function()
								if not syson and not stk.Visible then
									stk.Visible = true
								end
							end))
						end

						table.insert(ccon, tgui:GetPropertyChangedSignal("Enabled"):Connect(function()
							if syson and tgui.Enabled then
								tgui.Enabled = false
							elseif not syson and not tgui.Enabled then
								tgui.Enabled = true
							end
						end))
						tgui.Enabled = not syson

						synrc()
						fnd = true
					end
				end
			end)
			if fnd then break end
			task.wait(0.1)
		end
	end)

	task.spawn(function()
		while true do
			task.wait(0.2)
			if plr.Character ~= ch then break end
			local hm2 = ch:FindFirstChildOfClass("Humanoid")
			if hm2 then
				if hm2.Sit and isvst() then
					if syson then
						endft()
					end
				else
					if not syson then
						encst()
					end
				end
			end
		end
	end)
end

