local function isnwl()
	local ch = plr.Character
	if not ch then return false end
	local hm = ch:FindFirstChildOfClass("Humanoid")
	local hrp = ch:FindFirstChild("HumanoidRootPart")
	if not hm or not hrp then return false end
	if hm.FloorMaterial ~= Enum.Material.Air then return false end

	local prm = RaycastParams.new()
	prm.FilterDescendantsInstances = {ch}
	prm.FilterType = Enum.RaycastFilterType.Exclude

	local cam = workspace.CurrentCamera
	local ldir = cam and cam.CFrame.LookVector or hrp.CFrame.LookVector
	local rdir = cam and cam.CFrame.RightVector or hrp.CFrame.RightVector
	local udir = Vector3.new(0, 1, 0)

	local dirs = {
		ldir,
		-ldir,
		rdir,
		-rdir,
		(ldir + rdir).Unit,
		(ldir - rdir).Unit,
	}

	local offs = {
		Vector3.new(0, 0, 0),
		udir * 1,
		-udir * 0.5,
	}

	for _, d in ipairs(dirs) do
		for _, o in ipairs(offs) do
			local org = hrp.Position + o
			local res = workspace:Raycast(org, d * wjd, prm)
			if res and res.Instance and res.Instance.CanCollide then
				return true
			end
		end
	end
	return false
end

