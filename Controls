end)

local function updateJoyVisual(cpos, df)
    stick.Position = UDim2.new(0, cpos.X - 22.5, 0, cpos.Y - 22.5)
    for i, dt in ipairs(dots) do
        local rt = i / 7
        local dpos = startPos + (df * rt)
        dt.Position = UDim2.new(0, dpos.X - (dt.Size.X.Offset / 2), 0, dpos.Y - (dt.Size.Y.Offset / 2))
    end

    local dist = df.Magnitude
    local dir = dist > 0 and df.Unit or Vector2.new(0, 0)
    local intens = math.clamp(dist / 40, 0, 1)
    moveVec = Vector3.new(dir.X * intens, 0, dir.Y * intens)
end

capArea.InputBegan:Connect(function(inp)
    if not sysEnabled or isDrag then return end
    if inp.UserInputType ~= Enum.UserInputType.Touch and inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end

    if captureAnim then
        captureAnim = false
        capArea.BackgroundTransparency = 1
    end

    isDrag = true
    hasMoved = false
    dragInput = inp
    startPos = Vector2.new(inp.Position.X, inp.Position.Y)
end)

inputSvc.InputChanged:Connect(function(inp)
    if sysEnabled and isDrag and inp == dragInput then
        local cpos = Vector2.new(inp.Position.X, inp.Position.Y)
        local df = cpos - startPos

        if not hasMoved and df.Magnitude > 10 then
            hasMoved = true
            stickBase.Position = UDim2.new(0, startPos.X - 20, 0, startPos.Y - 20)
            stickBase.Visible = true
            stick.Visible = true
            for _, d in pairs(dots) do d.Visible = true end
        end
        if hasMoved then updateJoyVisual(cpos, df) end
    end
end)

inputSvc.InputEnded:Connect(function(inp)
    if inp == dragInput then resetJoystick() end
end)

inputSvc.WindowFocusReleased:Connect(function()
    resetJoystick()
    isHoldingJump = false
    jumpBtn.BackgroundTransparency = 0.5
    jumpBtn.ImageColor3 = Color3.fromRGB(255, 255, 255)
end)

runSvc.Heartbeat:Connect(function()
    local curPing = getPing()

    table.insert(pingHist, curPing)
    if #pingHist > maxPing then
        table.remove(pingHist, 1)
    end

    local pSum = 0
    for _, v in ipairs(pingHist) do pSum += v end
    local avgPing = pSum / #pingHist

    smoothPing = smoothPing + (avgPing - smoothPing) * 0.1

    local pSec = smoothPing / 1000
    coyoteTime = baseCoyote + (pSec * 1.2)
    bufferTime = baseBuffer + (pSec * 1.5)
end)
