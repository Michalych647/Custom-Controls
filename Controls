local isDrag = false
local dragInput = nil
local moveVec = Vector3.new(0, 0, 0)
local startPos = Vector2.new(0, 0)
local hasMoved = false

local function resetJoystick()
    isDrag = false
    hasMoved = false
    dragInput = nil
    stickBase.Visible = false
    stick.Visible = false
    for _, d in pairs(dots) do d.Visible = false end
    moveVec = Vector3.new(0, 0, 0)
end

local function enableCustomUI()
    sysEnabled = true
    capGui.Enabled = true
    jumpBtn.Visible = true
    pcall(function()
        local tGui = player.PlayerGui:FindFirstChild("TouchGui")
        if tGui then tGui.Enabled = false end
    end)
end

local function disableCustomUI()
    sysEnabled = false
    capGui.Enabled = false
    jumpBtn.Visible = true
    resetJoystick()
    pcall(function()
        local tGui = player.PlayerGui:FindFirstChild("TouchGui")
        if tGui then
            tGui.Enabled = true
            local frm = tGui:FindFirstChild("TouchControlFrame")
            if frm then
                frm.Visible = true
                local stk = frm:FindFirstChild("DynamicThumbstick")
                if stk then stk.Visible = true end
            end
        end
    end)
end

local function clearConns()
    for _, c in ipairs(charConns) do
        if c and c.Connected then c:Disconnect() end
    end
    charConns = {}
end

local function isVehicleSeat()
    local hum = getHum()
    if not hum then return false end
    if hum.Sit then
        local sp = hum.SeatPart
        if sp and sp:IsA("VehicleSeat") then
            return true
        end
    end
    return false
end

local function updateSeatState()
    local hum = getHum()
    if not hum then return end
    if hum.Sit and isVehicleSeat() then
        disableCustomUI()
    else
        enableCustomUI()
    end
end

local function getTouchFrame()
    local tGui = player.PlayerGui:FindFirstChild("TouchGui")
    if not tGui then return nil end
    return tGui:FindFirstChild("TouchControlFrame")
end

local function getThumbstick(frm)
    if not frm then return nil end
    local dthm = frm:FindFirstChild("DynamicThumbstickFrame")
    if dthm then return dthm end
    local stk = frm:FindFirstChild("DynamicThumbstick")
    if stk then
        local p = stk.Parent
        if p and p ~= frm then return p end
        return stk
    end
    return nil
end

local function getRobloxJump(frm)
    if not frm then return nil end
    return frm:FindFirstChild("JumpButton")
end

local function syncUI()
    local frm = getTouchFrame()
    if not frm then return end

    local dthm = getThumbstick(frm)
    if dthm then
        capArea.Size = dthm.Size
        capArea.Position = dthm.Position
    end

    local rJump = getRobloxJump(frm)
    if rJump then
        jumpBtn.Position = rJump.Position
        jumpBtn.Size = rJump.Size
    end
end

local function setupCharacter(c)
    clearConns()
    lastGrounded = 0
    lastJumpPress = 0
    lastJumpReq = 0
    isHoldingJump = false

    local hum = c:WaitForChild("Humanoid", 5)
    if not hum then return end

    updateSeatState()

    local seatConn = hum:GetPropertyChangedSignal("Sit"):Connect(function()
        local h = getHum()
        if not h then return end
        if h.Sit and isVehicleSeat() then
            disableCustomUI()
        else
            enableCustomUI()
            if isDrag and hasMoved then
                stickBase.Visible = true
                stick.Visible = true
                for _, d in pairs(dots) do d.Visible = true end
            end
        end
    end)
    table.insert(charConns, seatConn)

    local function handleLand()
        if tick() - lastJumpPress <= bufferTime then
            lastJumpPress = 0
            task.defer(function()
                if hum and hum:GetState() ~= Enum.HumanoidStateType.Jumping then
                    lastJumpReq = tick()
                    hum:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end)
        end
    end

    local stateConn = hum.StateChanged:Connect(function(old, new)
        if new == Enum.HumanoidStateType.Freefall then
            if tick() - lastJumpReq > 0.25 then
                lastGrounded = tick()
            end
        end
        if new == Enum.HumanoidStateType.Landed or new == Enum.HumanoidStateType.Running or new == Enum.HumanoidStateType.RunningNoPhysics then
            handleLand()
        end
    end)
    table.insert(charConns, stateConn)

    local floorConn = hum:GetPropertyChangedSignal("FloorMaterial"):Connect(function()
        if hum.FloorMaterial == Enum.Material.Air then
            if tick() - lastJumpReq > 0.25 then
                lastGrounded = tick()
            end
        else
            handleLand()
        end
    end)
    table.insert(charConns, floorConn)

    task.spawn(function()
        local attempts = 0
        while attempts < 30 do
            if player.Character ~= c then break end
            local found = false
            pcall(function()
                local tGui = player.PlayerGui:FindFirstChild("TouchGui")
                if tGui then
                    local frm = tGui:FindFirstChild("TouchControlFrame")
                    if frm then
                        local dthm = getThumbstick(frm)
                        if dthm then
                            table.insert(charConns, dthm:GetPropertyChangedSignal("Position"):Connect(syncUI))
                            table.insert(charConns, dthm:GetPropertyChangedSignal("Size"):Connect(syncUI))
                        end
                        local rJump = getRobloxJump(frm)
                        if rJump then
                            table.insert(charConns, rJump:GetPropertyChangedSignal("Position"):Connect(syncUI))
                            table.insert(charConns, rJump:GetPropertyChangedSignal("Size"):Connect(syncUI))
                            table.insert(charConns, rJump:GetPropertyChangedSignal("Visible"):Connect(function()
                                if rJump.Visible then rJump.Visible = false end
                            end))
                            rJump.Visible = false
                        end

                        local stk = frm:FindFirstChild("DynamicThumbstick")
                        if stk then
                            table.insert(charConns, stk:GetPropertyChangedSignal("Visible"):Connect(function()
                                if not sysEnabled and not stk.Visible then
                                    stk.Visible = true
                                end
                            end))
                        end

                        table.insert(charConns, tGui:GetPropertyChangedSignal("Enabled"):Connect(function()
                            if sysEnabled and tGui.Enabled then
                                tGui.Enabled = false
                            elseif not sysEnabled and not tGui.Enabled then
                                tGui.Enabled = true
                            end
                        end))
                        tGui.Enabled = not sysEnabled

                        syncUI()
                        found = true
                    end
                end
            end)
            if found then break end
            attempts += 1
            task.wait(0.2)
        end
    end)

    task.spawn(function()
        while true do
            task.wait(0.2)
            if player.Character ~= c then break end
            local h = c:FindFirstChildOfClass("Humanoid")
            if h then
                if h.Sit and isVehicleSeat() then
                    if sysEnabled then
                        disableCustomUI()
                    end
                else
                    if not sysEnabled then
                        enableCustomUI()
                    end
                end
            end
        end
    end)
end

