task.spawn(function()
	task.wait(0.1)
	caani = true
	carea.BackgroundTransparency = 0.5
	local elap = 0
	local dur = 1.5
	while elap < dur do
		if not caani then
			carea.BackgroundTransparency = 1
			return
		end
		elap = elap + task.wait()
	end
	if not caani then
		carea.BackgroundTransparency = 1
		return
	end
	local felap = 0
	local fdur = 0.6
	local st = 0.5
	local et = 1
	while felap < fdur do
		if not caani then
			carea.BackgroundTransparency = 1
			return
		end
		local dt = task.wait()
		felap = felap + dt
		local al = math.clamp(felap / fdur, 0, 1)
		carea.BackgroundTransparency = st + (et - st) * al
	end
	carea.BackgroundTransparency = 1
	caani = false
end)

local function hjr()
	local hm = gethm()
	if not hm then return end

	if hm.Sit then
		hm.Sit = false
		hm.Jump = true
		ljrt = tick()
		task.defer(function()
			if hm then hm:ChangeState(Enum.HumanoidStateType.Jumping) end
		end)
		return
	end

	local t = tick()
	local st = hm:GetState()
	local ina = (hm.FloorMaterial == Enum.Material.Air)
	local cok = (t - lgt <= ct) and (lgt > 0)

	if st == Enum.HumanoidStateType.Climbing then
		hm:ChangeState(Enum.HumanoidStateType.Jumping)
		return
	end

	if not ina or cok then
		lgt = 0
		ljrt = tick()
		hm:ChangeState(Enum.HumanoidStateType.Jumping)
		return
	end

	if ina then
		local tslt = t - ljtt
		if tslt < wtw then
			jtc = jtc + 1
		else
			jtc = 1
		end
		ljtt = t

		if jtc >= 2 and t > wjct and not wju then
			if isnwl() then
				jtc = 0
				wju = true
				wjct = t + wjc
				ljrt = tick()
				hm:ChangeState(Enum.HumanoidStateType.Jumping)
				return
			end
		end
		ljpt = t
	end
end

