local function dconn()
	for _, c in ipairs(cconn) do
		if c and c.Connected then
			c:Disconnect()
		end
	end
	cconn = {}
end

local function isVehicleSeat()
	local ch = plr.Character
	if not ch then return false end
	local hm = ch:FindFirstChildOfClass("Humanoid")
	if not hm then return false end
	if hm.Sit then
		local sp = hm.SeatPart
		if sp and sp:IsA("VehicleSeat") then
			return true
		end
	end
	return false
end

local function updst()
	local hm = gethm()
	if not hm then return end
	if hm.PlatformStand then
		enableDefault()
	elseif hm.Sit and isVehicleSeat() then
		enableDefault()
	else
		enableCustom()
	end
end

local function findTouchFrame()
	local tgui = plr.PlayerGui:FindFirstChild("TouchGui")
	if not tgui then return nil end
	local frm = tgui:FindFirstChild("TouchControlFrame")
	return frm
end

local function findThumbstickFrame(frm)
	if not frm then return nil end
	local dthm = frm:FindFirstChild("DynamicThumbstickFrame")
	if dthm then return dthm end
	local stk = frm:FindFirstChild("DynamicThumbstick")
	if stk then
		local p = stk.Parent
		if p and p ~= frm then return p end
		return stk
	end
	return nil
end

local function findJumpButton(frm)
	if not frm then return nil end
	return frm:FindFirstChild("JumpButton")
end

local function syncRects()
	local frm = findTouchFrame()
	if not frm then return end

	local dthm = findThumbstickFrame(frm)
	if dthm then
		local pos = dthm.Position
		local sz = dthm.Size
		carea.Size = sz
		carea.Position = pos
	end

	local njmp = findJumpButton(frm)
	if njmp then
		local pos = njmp.Position
		local sz = njmp.Size
		jbtn.Position = pos
		jbtn.Size = sz
	end
end

local function setup(ch)
	dconn()
	lgt = 0
	ljpt = 0
	ljtt = 0
	jtc = 0
	wjct = 0
	wju = false
	ijh = false

	local hm = ch:WaitForChild("Humanoid", 5)
	if not hm then return end

	updst()
	local cs = hm:GetPropertyChangedSignal("Sit"):Connect(function()
		local hm2 = gethm()
		if not hm2 then return end
		if hm2.PlatformStand then
			enableDefault()
		elseif hm2.Sit and isVehicleSeat() then
			enableDefault()
		else
			enableCustom()
			if drag and monce then
				base.Visible = true
				stick.Visible = true
				for _, d in pairs(dots) do d.Visible = true end
			end
		end
	end)
	local cp = hm:GetPropertyChangedSignal("PlatformStand"):Connect(updst)
	table.insert(cconn, cs)
	table.insert(cconn, cp)

	local function handleLanding()
		jtc = 0
		wju = false
		if tick() - ljpt <= bt then
			ljpt = 0
			task.defer(function()
				if hm and hm:GetState() ~= Enum.HumanoidStateType.Jumping then
					ljrt = tick()
					hm:ChangeState(Enum.HumanoidStateType.Jumping)
				end
			end)
		end
	end

	local c2 = hm.StateChanged:Connect(function(o, n)
		if n == Enum.HumanoidStateType.Freefall then
			if tick() - ljrt > 0.25 then
				lgt = tick()
			end
		end

		if n == Enum.HumanoidStateType.Landed or n == Enum.HumanoidStateType.Running or n == Enum.HumanoidStateType.RunningNoPhysics then
			handleLanding()
		end
	end)
	table.insert(cconn, c2)

	local c3 = hm:GetPropertyChangedSignal("FloorMaterial"):Connect(function()
		if hm.FloorMaterial == Enum.Material.Air then
			if tick() - ljrt > 0.25 then
				lgt = tick()
			end
		else
			handleLanding()
		end
	end)
	table.insert(cconn, c3)

	task.spawn(function()
		while true do
			if plr.Character ~= ch then break end
			local found = false
			pcall(function()
				local tgui = plr.PlayerGui:FindFirstChild("TouchGui")
				if tgui then
					local frm = tgui:FindFirstChild("TouchControlFrame")
					if frm then
						local dthm = findThumbstickFrame(frm)
						if dthm then
							table.insert(cconn, dthm:GetPropertyChangedSignal("Position"):Connect(syncRects))
							table.insert(cconn, dthm:GetPropertyChangedSignal("Size"):Connect(syncRects))
						end
						local njmp = findJumpButton(frm)
						if njmp then
							table.insert(cconn, njmp:GetPropertyChangedSignal("Position"):Connect(syncRects))
							table.insert(cconn, njmp:GetPropertyChangedSignal("Size"):Connect(syncRects))
							table.insert(cconn, njmp:GetPropertyChangedSignal("Visible"):Connect(function()
								if njmp.Visible then njmp.Visible = false end
							end))
							njmp.Visible = false
						end

						local stk = frm:FindFirstChild("DynamicThumbstick")
						if stk then
							table.insert(cconn, stk:GetPropertyChangedSignal("Visible"):Connect(function()
								if not syson and not stk.Visible then
									stk.Visible = true
								end
							end))
						end

						table.insert(cconn, tgui:GetPropertyChangedSignal("Enabled"):Connect(function()
							if syson and tgui.Enabled then
								tgui.Enabled = false
							elseif not syson and not tgui.Enabled then
								tgui.Enabled = true
							end
						end))
						tgui.Enabled = not syson

						syncRects()
						found = true
					end
				end
			end)
			if found then break end
			task.wait(0.1)
		end
	end)

	task.spawn(function()
		while true do
			task.wait(0.2)
			if plr.Character ~= ch then break end
			local hm2 = ch:FindFirstChildOfClass("Humanoid")
			if hm2 then
				if hm2.PlatformStand then
					if syson then
						enableDefault()
					end
				elseif hm2.Sit and isVehicleSeat() then
					if syson then
						enableDefault()
					end
				else
					if not syson then
						enableCustom()
					end
				end
			end
		end
	end)
end

